# Backend Environment Variables
# Render exposes PORT automatically, but we define it here for local use
PORT=5000

# Security (Replace this with a strong random string before deploying)
JWT_SECRET=your_super_secret_jwt_key_please_change

# Supabase (Both these keys come from your Supabase Dashboard -> Project Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# CORS Configuration (Set to your Vercel deployment URL in production)
FRONTEND_URL=http://localhost:5173
